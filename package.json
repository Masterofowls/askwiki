{
  "name": "askwiki",
  "version": "1.0.0",
  "description": "AskWiki - A modern Wikipedia clone with dark theme and advanced search",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "node -e \"const fs=require('fs');['dist','coverage','node_modules/.cache'].forEach(d=>{try{fs.rmSync(d,{recursive:true,force:true})}catch(e){}})\"",
    "type-check": "tsc --noEmit",
    "lint": "biome check --write .",
    "lint:ci": "biome ci .",
    "lint:styles": "stylelint \"src/**/*.css\"",
    "lint:styles:fix": "stylelint --fix \"src/**/*.css\"",
    "format": "biome format --write .",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch --passWithNoTests",
    "test:coverage": "jest --coverage --passWithNoTests",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:all": "npm run test:coverage && npm run test:e2e",
    "depcheck": "depcheck",
    "knip": "knip",
    "ncu": "ncu",
    "ncu:update": "ncu -u",
    "ncu:auto": "ncu -u --upgrade",
    "check:compat": "node scripts/check-compatibility.mjs",
    "seo": "seo-analyzer dist/**/*.html",
    "security": "npm audit --audit-level=moderate",
    "security:ci": "audit-ci --high",
    "verify": "npm run type-check && npm run lint:ci && npm run knip && npm run test && npm run build && npm run security:ci",
    "verify:all": "npm run verify && npm run check:compat",
    "env:pull": "dotenvx pull",
    "env:push": "dotenvx push"
  },
  "keywords": [
    "typescript",
    "template",
    "reusable"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@dotenvx/dotenvx": "^1.29.1",
    "@playwright/test": "^1.54.2",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.0.1",
    "@types/jest": "^29.5.14",
    "@types/katex": "^0.16.8",
    "@types/node": "^22.12.0",
    "@types/react": "^18.3.16",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "audit-ci": "^7.1.0",
    "depcheck": "^1.4.7",
    "dotenv": "^16.5.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "knip": "^6.23.0",
    "npm-check-updates": "^17.1.15",
    "seo-analyzer": "^3.2.0",
    "stylelint": "^16.12.0",
    "stylelint-config-standard": "^36.0.1",
    "ts-jest": "^29.2.5",
    "typescript": "^5.7.3",
    "vite": "^6.0.11",
    "vite-plugin-pwa": "^1.3.0"
  },
  "dependencies": {
    "@neondatabase/auth-ui": "^0.2.1-beta",
    "@neondatabase/neon-js": "^0.6.2-beta",
    "@neondatabase/serverless": "^1.1.0",
    "drizzle-orm": "^0.45.2",
    "katex": "^0.17.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.4",
    "zod": "^4.4.3"
  }
}
